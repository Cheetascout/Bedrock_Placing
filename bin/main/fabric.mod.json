{
  "schemaVersion": 1,
  "id": "bedrock_placing",
  "version": "${version}",
  "name": "Bedrock Placing",
  "description": "Removes the 4 tick delay between placing blocks by holding right click",
  "authors": [""],
  "license": "ARR",
  "icon": "assets/bedrock_placing/icon.png",
  "environment": "*",
  "entrypoints": {
    "fabric-datagen": [
      "org.bedrock.placing.bedrock_placing.client.Bedrock_placingDataGenerator"
    ],
    "client": [
      "org.bedrock.placing.bedrock_placing.client.Bedrock_PlacingClient"
    ],
    "main": [
      "org.bedrock.placing.bedrock_placing.Server"
    ],
    "modmenu": [
      "org.bedrock.placing.bedrock_placing.ModMenuIntegration"
    ]
  },
  "mixins": [
    "bedrock_placing.mixins.json",
    {
      "config": "bedrock_placing.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  },
  "suggests": {
    "modmenu": "*"
  }
}
